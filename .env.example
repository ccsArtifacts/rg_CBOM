# ==========================================
# PQC Platform - Environment Configuration
# ==========================================

# Database
DB_PASSWORD=pqc_secure_pass_2024
POSTGRES_DB=pqc_inventory
POSTGRES_USER=pqc_user

# Neo4j
NEO4J_PASSWORD=pqc_graph_2024

# Elasticsearch
ELASTIC_PASSWORD=pqc_elastic_2024

# Redis
REDIS_PASSWORD=pqc_redis_2024

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=pqc-dev-token-2024

# Backend
PORT=8080
ENV=development
LOG_LEVEL=info
TLS_CERT=/etc/pqc/tls/server.crt
TLS_KEY=/etc/pqc/tls/server.key

# Frontend
REACT_APP_API_URL=https://localhost:8080/api
REACT_APP_WS_URL=wss://localhost:8080/ws

# Auth
JWT_SECRET=pqc_jwt_secret_key_change_in_production_2024
JWT_EXPIRATION_HOURS=24
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Security
ENABLE_RBAC=true
ENABLE_AUDIT_LOG=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Integration
GITHUB_WEBHOOK_SECRET=change_me_in_production
GITLAB_TOKEN=change_me_in_production
JENKINS_URL=https://jenkins.example.com
JIRA_API_URL=https://jira.example.com

# SBOM Settings
MAX_SBOM_SIZE_MB=500
SBOM_RETENTION_DAYS=365
ENABLE_AUTO_SCAN=true

# PQC Migration
RECOMMENDED_PQC_KEM=ML-KEM-768
RECOMMENDED_PQC_SIGNATURE=ML-DSA-65
PQC_MIGRATION_DEADLINE_YEARS=3

# Monitoring
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
ENABLE_JAEGER=false
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# Compliance
ANSSI_COMPLIANCE_MODE=true
HDS_COMPLIANCE_MODE=true
NIS2_COMPLIANCE_MODE=false
